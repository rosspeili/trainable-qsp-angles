{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rosspeili/trainable-qsp-angles/results/schema.json",
  "title": "Trainable QSP experiment run",
  "type": "object",
  "required": ["run_type", "timestamp_utc", "schema_version"],
  "properties": {
    "schema_version": { "type": "string" },
    "run_type": {
      "enum": ["gradient_train", "analytic_baseline", "sweep_summary", "comparison_table"]
    },
    "timestamp_utc": { "type": "string" },
    "config": { "type": "object" },
    "phases_init": { "type": "array", "items": { "type": "number" } },
    "phases_final": { "type": "array", "items": { "type": "number" } },
    "angles": { "type": "array", "items": { "type": "number" } },
    "loss_init": { "type": "number" },
    "loss_final": { "type": "number" },
    "loss_history": { "type": "array", "items": { "type": "number" } },
    "train_time_s": { "type": "number" },
    "solve_time_s": { "type": "number" },
    "gradient_norm_final": { "type": "number" },
    "metrics": {
      "type": "object",
      "properties": {
        "train_mse": { "type": "number" },
        "holdout_mse": { "type": "number" },
        "train_max_error": { "type": "number" },
        "holdout_max_error": { "type": "number" }
      }
    },
    "solver": { "type": "string" },
    "seeds": { "type": "array" },
    "runs": { "type": "array" },
    "summary": { "type": "object" }
  }
}
